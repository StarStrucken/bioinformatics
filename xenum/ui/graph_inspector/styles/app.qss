QWidget {
    background: white;
    color: black;
}
QTableWidget {
    background: white;
    color: black;
    gridline-color: #cccccc;
    alternate-background-color: #fafafa;
}
QHeaderView::section {
    background: #eeeeee;
    color: black;
    padding: 3px;
}
QLabel {
    color: black;
}
QPlainTextEdit {
    background: #fafafa;
    color: black;
    border: 1px solid #cccccc;
}
