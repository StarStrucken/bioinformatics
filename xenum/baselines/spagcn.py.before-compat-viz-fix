#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
from pathlib import Path
import random
import sys
import time

import numpy as np
import pandas as pd

from xenum.dump.io import load_xenium
from xenum_paths import ROOT, data_dir, out_dir as make_out_dir

BASELINE_NAME = "spagcn"
DEFAULT_SPAGCN_SOURCE = ROOT / "external" / "SpaGCN" / "SpaGCN_package"

def parse_args():
    parser = argparse.ArgumentParser()
    parser.add_argument("dataset_id")
    return parser.parse_args()


def runtime_config(dataset_id):
    return argparse.Namespace(
        dataset_id=dataset_id,
        out_dir=None,
        spagcn_source=str(DEFAULT_SPAGCN_SOURCE),
        histology="auto",
        image=None,
        graph_k=12,
        num_pcs=50,
        min_cells=3,
        p=0.5,
        l=None,
        resolution=0.4,
        lr=0.005,
        max_epochs=200,
        tol=5e-3,
        alpha=1.0,
        beta=49,
        seed=100,
        refine_shape="none",
        write_adj=False,
    )

def baseline_dir(dataset_id, override=None):
    if override:
        p = Path(override)
    else:
        p = make_out_dir(dataset_id) / "baselines" / BASELINE_NAME
    p.mkdir(parents=True, exist_ok=True)
    return p

def import_spagcn(source):
    source_path = Path(source)

    if source_path.exists():
        sys.path.insert(0, str(source_path))

    import SpaGCN as spg
    return spg

def normalize_for_spagcn(adata, spg, min_cells):
    import scanpy as sc

    adata = adata.copy()

    cell_totals = np.asarray(adata.X.sum(axis=1)).reshape(-1)
    keep_cells = np.isfinite(cell_totals) & (cell_totals > 0)

    if not keep_cells.any():
        raise RuntimeError("SpaGCN preprocessing found no cells with expression counts")

    if not keep_cells.all():
        adata = adata[keep_cells].copy()

    adata.var_names = [str(x).upper() for x in adata.var_names]
    adata.var_names_make_unique()
    adata.var["genename"] = adata.var_names.astype(str)

    spg.prefilter_genes(adata, min_cells=int(min_cells))
    spg.prefilter_specialgenes(adata)

    if adata.n_vars == 0:
        raise RuntimeError("SpaGCN preprocessing removed all genes")

    sc.pp.normalize_total(adata, target_sum=1e4)
    sc.pp.log1p(adata)

    return adata

def find_default_image(dataset_id):
    root = data_dir(dataset_id)

    candidates = []

    if root.exists():
        candidates.extend(sorted((root / "morphology_focus").glob("*.ome.tif")))
        candidates.extend(sorted((root / "morphology_focus").glob("*.tif")))
        candidates.extend(sorted((root / "morphology_focus").glob("*.tiff")))
        candidates.extend(sorted((root / "morphology_focus").glob("*.png")))
        candidates.extend(sorted((root / "morphology_focus").glob("*.jpg")))
        candidates.extend(sorted((root / "morphology_focus").glob("*.jpeg")))

        for name in [
            "morphology.ome.tif",
            "morphology.tif",
            "histology.tif",
            "histology.png",
            "histology.jpg",
        ]:
            p = root / name
            if p.exists():
                candidates.append(p)

    return candidates[0] if candidates else None

def read_image(path):
    if path is None:
        return None, "no image path"

    try:
        import cv2
    except Exception as e:
        return None, "cv2 import failed: {}: {}".format(type(e).__name__, e)

    img = cv2.imread(str(path), cv2.IMREAD_UNCHANGED)

    if img is None:
        return None, "cv2.imread returned None"

    img = np.asarray(img)

    if img.ndim == 2:
        img = np.stack([img, img, img], axis=2)
    elif img.ndim == 3 and img.shape[2] > 3:
        img = img[:, :, :3]
    elif img.ndim != 3:
        return None, "unsupported image shape {}".format(img.shape)

    return img, None

def image_pixel_coords(coords, image):
    x = coords[:, 0]
    y = coords[:, 1]
    h, w = image.shape[:2]

    yx_ok = (
        np.nanmin(x) >= 0
        and np.nanmin(y) >= 0
        and np.nanmax(x) < w
        and np.nanmax(y) < h
    )

    if yx_ok:
        return np.rint(y).astype(int).tolist(), np.rint(x).astype(int).tolist(), "row=y,column=x"

    xy_ok = (
        np.nanmin(x) >= 0
        and np.nanmin(y) >= 0
        and np.nanmax(x) < h
        and np.nanmax(y) < w
    )

    if xy_ok:
        return np.rint(x).astype(int).tolist(), np.rint(y).astype(int).tolist(), "row=x,column=y"

    return None, None, "centroids outside image bounds image_shape={} x_range=({:.3f},{:.3f}) y_range=({:.3f},{:.3f})".format(
        image.shape,
        float(np.nanmin(x)),
        float(np.nanmax(x)),
        float(np.nanmin(y)),
        float(np.nanmax(y)),
    )

def calculate_adj(spg, coords, args, out):
    x = coords[:, 0].astype(float).tolist()
    y = coords[:, 1].astype(float).tolist()
    image_path = Path(args.image) if args.image else find_default_image(args.dataset_id)

    image_meta = {
        "histology_requested": args.histology,
        "histology_used": False,
        "image_path": str(image_path) if image_path else None,
        "reason": None,
        "pixel_orientation": None,
    }

    if args.histology != "off":
        image, reason = read_image(image_path)

        if image is not None:
            x_pixel, y_pixel, orientation = image_pixel_coords(coords, image)

            if x_pixel is not None:
                image_meta.update({
                    "histology_used": True,
                    "pixel_orientation": orientation,
                    "image_shape": list(image.shape),
                })
                adj = spg.calculate_adj_matrix(
                    x=x,
                    y=y,
                    x_pixel=x_pixel,
                    y_pixel=y_pixel,
                    image=image,
                    beta=int(args.beta),
                    alpha=float(args.alpha),
                    histology=True,
                )
                return adj, image_meta

            reason = orientation

        image_meta["reason"] = reason

        if args.histology == "on":
            raise RuntimeError("SpaGCN histology requested but unavailable: {}".format(reason))

    image_meta["reason"] = image_meta["reason"] or "histology disabled"
    adj = spg.calculate_adj_matrix(x=x, y=y, histology=False)
    return adj, image_meta

def graph_edges_from_adj(adj, l_value, cell_ids, k):
    n = int(adj.shape[0])
    rows = []
    k = max(1, min(int(k), max(1, n - 1)))

    for source in range(n):
        order = np.argsort(adj[source])
        rank = 0

        for target in order:
            target = int(target)

            if target == source:
                continue

            rank += 1
            edge_source = min(source, target)
            edge_target = max(source, target)
            distance = float(adj[source, target])
            weight = float(np.exp(-1.0 * (distance ** 2) / (2.0 * (float(l_value) ** 2)))) if l_value > 0 else np.nan
            rows.append((
                edge_source,
                edge_target,
                source,
                target,
                rank,
                distance,
                weight,
                str(cell_ids[edge_source]),
                str(cell_ids[edge_target]),
            ))

            if rank >= k:
                break

    edges = pd.DataFrame(rows, columns=[
        "source",
        "target",
        "directed_source",
        "directed_target",
        "rank",
        "neighbor_distance",
        "neighbor_weight",
        "source_cell_id",
        "target_cell_id",
    ])

    if edges.empty:
        return edges

    edges = (
        edges
        .sort_values(["neighbor_distance", "rank"])
        .drop_duplicates(["source", "target"])
        .sort_values(["source", "target"])
        .reset_index(drop=True)
    )

    return edges

def xy_benchmark_from_edges(dataset_id, nodes, edges, k):
    xy = nodes[["x_centroid", "y_centroid"]].to_numpy(dtype=np.float64)
    n = len(nodes)
    sx = np.zeros(n, dtype=np.float64)
    sy = np.zeros(n, dtype=np.float64)
    sw = np.zeros(n, dtype=np.float64)
    cnt = np.zeros(n, dtype=np.int64)

    for r in edges.itertuples(index=False):
        a = int(r.source)
        b = int(r.target)
        w = float(r.neighbor_weight)

        if not np.isfinite(w) or w <= 0:
            w = 1.0

        sx[a] += w * xy[b, 0]
        sy[a] += w * xy[b, 1]
        sw[a] += w
        cnt[a] += 1

        sx[b] += w * xy[a, 0]
        sy[b] += w * xy[a, 1]
        sw[b] += w
        cnt[b] += 1

    ok = sw > 0
    pred = np.full((n, 2), np.nan, dtype=np.float64)
    pred[ok, 0] = sx[ok] / sw[ok]
    pred[ok, 1] = sy[ok] / sw[ok]
    err = np.sqrt(((pred - xy) ** 2).sum(axis=1))
    ok_err = err[ok]
    center = xy.mean(axis=0) if n else np.zeros(2, dtype=np.float64)
    center_err = np.sqrt(((xy - center) ** 2).sum(axis=1))

    pred_df = pd.DataFrame({
        "node": np.arange(n, dtype=np.int64),
        "cell_id": nodes["cell_id"].to_numpy(dtype=str),
        "x": xy[:, 0],
        "y": xy[:, 1],
        "pred_x": pred[:, 0],
        "pred_y": pred[:, 1],
        "error": err,
        "used_neighbors": cnt,
        "neighbor_weight_sum": sw,
        "measurement": "spagcn_adjacency",
        "k": int(k),
    })

    row = {
        "dataset": dataset_id,
        "baseline": BASELINE_NAME,
        "measurement": "spagcn_adjacency",
        "k": int(k),
        "leaky": True,
        "n_nodes": int(n),
        "n_edges": int(len(edges)),
        "coverage": float(ok.mean()) if n else 0.0,
        "mean_xy_error": float(ok_err.mean()) if len(ok_err) else None,
        "median_xy_error": float(np.median(ok_err)) if len(ok_err) else None,
        "p90_xy_error": float(np.quantile(ok_err, 0.90)) if len(ok_err) else None,
        "center_median_error": float(np.median(center_err)) if len(center_err) else None,
        "median_vs_center": float(np.median(ok_err) / np.median(center_err)) if len(ok_err) and np.median(center_err) > 0 else None,
    }

    return pred_df, row

def domain_summary(domains, domain_col):
    rows = []

    for domain, group in domains.groupby(domain_col):
        xy = group[["x", "y"]].to_numpy(dtype=np.float64)
        center = xy.mean(axis=0)
        radius = np.sqrt(((xy - center) ** 2).sum(axis=1))
        rows.append({
            "domain": domain,
            "n_cells": int(len(group)),
            "center_x": float(center[0]),
            "center_y": float(center[1]),
            "mean_xy_radius": float(radius.mean()) if len(radius) else None,
            "median_xy_radius": float(np.median(radius)) if len(radius) else None,
            "p90_xy_radius": float(np.quantile(radius, 0.90)) if len(radius) else None,
        })

    return pd.DataFrame(rows).sort_values(["domain"]).reset_index(drop=True)

def write_run_note(out_dir, summary):
    lines = [
        "# SpaGCN Baseline",
        "",
        "1. Source: external SpaGCN checkout or installed `SpaGCN` package.",
        "2. Scope: optional external baseline; not used by learned_mix.",
        "3. Outputs: domains, probabilities, SpaGCN adjacency top-k graph, XY reconstruction benchmark, runtime summary.",
        "4. Status: `{}`.".format(summary.get("status")),
        "",
        "Key files:",
        "",
        "- `domains.csv`",
        "- `probabilities.csv`",
        "- `edges.csv`",
        "- `predictions_spagcn_adjacency_k{}.csv`".format(summary.get("graph_k")),
        "- `bench_xy.csv`",
        "- `domains_summary.csv`",
        "- `summary.json`",
    ]
    (out_dir / "README.md").write_text("\n".join(lines) + "\n")

def run(dataset_id):
    args = runtime_config(dataset_id)
    started = time.perf_counter()
    out = baseline_dir(args.dataset_id, args.out_dir)

    summary = {
        "baseline": BASELINE_NAME,
        "dataset": args.dataset_id,
        "status": "started",
        "output_dir": str(out),
        "spagcn_source": args.spagcn_source,
        "command": sys.argv,
        "graph_k": int(args.graph_k),
    }

    try:
        spg = import_spagcn(args.spagcn_source)
    except Exception as e:
        summary.update({
            "status": "missing_dependency",
            "error": "{}: {}".format(type(e).__name__, e),
            "runtime_sec": time.perf_counter() - started,
        })
        (out / "summary.json").write_text(json.dumps(summary, indent=2) + "\n")
        write_run_note(out, summary)
        raise SystemExit("SpaGCN import failed; run with XENUM_SPAGCN_PYTHON pointing at a SpaGCN environment")

    import torch

    random.seed(int(args.seed))
    np.random.seed(int(args.seed))
    torch.manual_seed(int(args.seed))

    adata_raw = load_xenium(data_dir(args.dataset_id))
    raw_n_cells = int(adata_raw.n_obs)
    adata = normalize_for_spagcn(adata_raw, spg, args.min_cells)

    nodes = pd.DataFrame({
        "cell_id": adata.obs["cell_id"].to_numpy(dtype=str),
        "x_centroid": adata.obs["x_centroid"].to_numpy(dtype=np.float64),
        "y_centroid": adata.obs["y_centroid"].to_numpy(dtype=np.float64),
    })
    coords = nodes[["x_centroid", "y_centroid"]].to_numpy(dtype=np.float64)

    t_adj = time.perf_counter()
    adj, image_meta = calculate_adj(spg, coords, args, out)
    adj_sec = time.perf_counter() - t_adj

    if adata.n_obs != adj.shape[0] or adj.shape[0] != adj.shape[1]:
        raise RuntimeError(
            "SpaGCN input shape mismatch after preprocessing: "
            f"adata={adata.shape}, adjacency={adj.shape}"
        )

    if args.write_adj:
        np.save(out / "adjacency.npy", adj)

    positive_adj = adj[np.isfinite(adj) & (adj > 0)]
    adj_stats = {
        "n": int(adj.shape[0]),
        "min_positive": float(positive_adj.min()) if len(positive_adj) else None,
        "median_positive": float(np.median(positive_adj)) if len(positive_adj) else None,
        "p90_positive": float(np.quantile(positive_adj, 0.90)) if len(positive_adj) else None,
        "max": float(np.nanmax(adj)) if adj.size else None,
    }

    num_pcs = min(int(args.num_pcs), max(1, adata.n_obs - 1), max(1, adata.n_vars - 1))

    if args.l is None:
        l_value = spg.search_l(float(args.p), adj, start=0.01, end=1000, tol=0.01, max_run=100)

        if l_value is None:
            l_value = adj_stats["median_positive"] or 1.0
    else:
        l_value = float(args.l)

    t_train = time.perf_counter()
    clf = spg.SpaGCN()
    clf.set_l(float(l_value))
    clf.train(
        adata,
        adj,
        num_pcs=int(num_pcs),
        init_spa=True,
        init="louvain",
        res=float(args.resolution),
        tol=float(args.tol),
        lr=float(args.lr),
        max_epochs=int(args.max_epochs),
    )
    y_pred, prob = clf.predict()
    train_sec = time.perf_counter() - t_train

    domains = pd.DataFrame({
        "node": np.arange(len(nodes), dtype=np.int64),
        "cell_id": nodes["cell_id"].to_numpy(dtype=str),
        "x": nodes["x_centroid"].to_numpy(dtype=np.float64),
        "y": nodes["y_centroid"].to_numpy(dtype=np.float64),
        "domain": y_pred.astype(int),
        "max_probability": np.max(prob, axis=1) if len(prob) else np.array([], dtype=float),
    })

    domain_col = "domain"

    if args.refine_shape != "none":
        adj_2d = spg.calculate_adj_matrix(
            x=coords[:, 0].astype(float).tolist(),
            y=coords[:, 1].astype(float).tolist(),
            histology=False,
        )
        refined = spg.refine(
            sample_id=domains["cell_id"].astype(str).tolist(),
            pred=domains["domain"].tolist(),
            dis=adj_2d,
            shape=args.refine_shape,
        )
        domains["refined_domain"] = pd.Series(refined).astype(int).to_numpy()
        domain_col = "refined_domain"

    prob_df = pd.DataFrame(prob, columns=["prob_{}".format(i) for i in range(prob.shape[1])])
    prob_df.insert(0, "cell_id", nodes["cell_id"].to_numpy(dtype=str))
    prob_df.insert(0, "node", np.arange(len(nodes), dtype=np.int64))

    edges = graph_edges_from_adj(adj, float(l_value), nodes["cell_id"].to_numpy(dtype=str), int(args.graph_k))
    pred_df, bench_row = xy_benchmark_from_edges(args.dataset_id, nodes, edges, int(args.graph_k))
    domain_stats = domain_summary(domains, domain_col)

    domains.to_csv(out / "domains.csv", index=False)
    prob_df.to_csv(out / "probabilities.csv", index=False)
    edges.to_csv(out / "edges.csv", index=False)
    pred_df.to_csv(out / "predictions_spagcn_adjacency_k{}.csv".format(int(args.graph_k)), index=False)
    pd.DataFrame([bench_row]).to_csv(out / "bench_xy.csv", index=False)
    domain_stats.to_csv(out / "domains_summary.csv", index=False)

    summary.update({
        "status": "ok",
        "n_cells_raw": raw_n_cells,
        "n_cells": int(adata.n_obs),
        "n_cells_removed_zero_counts": raw_n_cells - int(adata.n_obs),
        "n_genes_after_spagcn_filter": int(adata.n_vars),
        "num_pcs": int(num_pcs),
        "domains": int(domains[domain_col].nunique()),
        "domain_column": domain_col,
        "l": float(l_value),
        "p": float(args.p),
        "resolution": float(args.resolution),
        "max_epochs": int(args.max_epochs),
        "seed": int(args.seed),
        "histology": image_meta,
        "adjacency_stats": adj_stats,
        "runtime_sec": time.perf_counter() - started,
        "adjacency_runtime_sec": adj_sec,
        "train_runtime_sec": train_sec,
        "outputs": {
            "domains": "domains.csv",
            "probabilities": "probabilities.csv",
            "edges": "edges.csv",
            "predictions": "predictions_spagcn_adjacency_k{}.csv".format(int(args.graph_k)),
            "bench_xy": "bench_xy.csv",
            "domains_summary": "domains_summary.csv",
        },
        "environment": {
            "python": sys.version,
            "executable": sys.executable,
            "pid": os.getpid(),
            "spagcn_version": getattr(spg, "__version__", None),
        },
    })

    (out / "summary.json").write_text(json.dumps(summary, indent=2) + "\n")
    write_run_note(out, summary)

    print("SpaGCN baseline saved: {}".format(out), flush=True)


def main():
    args = parse_args()
    run(args.dataset_id)


if __name__ == "__main__":
    main()
